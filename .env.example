# =============================================================================
# DataAndAIPulse - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The main dashboard works without any API key.
# API credentials are only needed for the AI Chat page.
# =============================================================================

# -----------------------------------------------------------------------------
# Option A: Azure OpenAI (recommended)
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini   # alias, used if CHAT_DEPLOYMENT_NAME is not set

# -----------------------------------------------------------------------------
# Option B: OpenAI (alternative to Azure OpenAI)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL_ID=gpt-4o-mini

# -----------------------------------------------------------------------------
# Optional tuning
# -----------------------------------------------------------------------------
FETCH_TIMEOUT_SECONDS=20   # per-URL request timeout in seconds (default: 20)
CACHE_TTL_MINUTES=30       # how long fetched results are cached  (default: 30)
